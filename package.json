{
  "name": "revue",
  "version": "1.0.0",
  "description": "Automated GitHub PR code review system using Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "review": "tsx src/review-cli.ts",
    "reset": "tsx src/reset-cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test-notify": "tsx scripts/test-notify.ts",
    "generate-icon": "node scripts/generate-icon.mjs",
    "generate-sound": "node scripts/generate-sound.mjs",
    "stop": "pm2 stop gthub-server",
    "restart": "pm2 restart gthub-server",
    "logs": "pm2 logs gthub-server",
    "status": "pm2 describe gthub-server"
  },
  "dependencies": {
    "node-notifier": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-notifier": "^8.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
}
